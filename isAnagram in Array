class Solution {
    public boolean isAnagram(String s, String t) {
      int fre[] = new int[26];
      for(int i:s.toCharArray()){
        fre[i-'a']++;
      }
      for(int i:t.toCharArray()){
        fre[i-'a']--;
      }
      for(int i=0;i<fre.length;i++){
        if(fre[i]!=0) return false;
      }
      return true;
    }
}
